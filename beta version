                        <div class="md:w-1/2 md:text-left md:pl-12 mb-6 md:mb-0">
                            <div class="glass rounded-xl p-6 premium-shadow">
                                <p class="mono text-[10px] text-gray-500 uppercase tracking-widest mb-1">Season 2 · 2024</p>
                                <h3 class="oswald text-2xl uppercase italic rank-gold mb-3">The Expansion</h3>
                                <div class="space-y-2 text-sm text-gray-400">
