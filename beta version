                            <div class="glass rounded-xl p-6 premium-shadow border border-[#D4AF37]/20">
                                <p class="mono text-[10px] text-gray-500 uppercase tracking-widest mb-1">Season 3 · 2025</p>
                                <h3 class="oswald text-2xl uppercase italic rank-gold mb-3">The Reckoning</h3>
