<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>It's the Climb | DB4 Sports Official Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Oswald:wght@500;700;800&family=JetBrains+Mono:wght@400;700&display=swap');

        :root {
            --db4-gold: #D4AF37;
            --db4-emerald: #008542;
            --db4-silver: #C0C0C0;
            --db4-rust: #8B4513;
            --bg-dark: #0A0B0E;
            --card-bg: #141418;
            --card-border: #222228;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: #e5e5e5;
            overflow-x: hidden;
        }
        body.modal-open { overflow: hidden; }

        .oswald { font-family: 'Oswald', sans-serif; }
        .mono { font-family: 'JetBrains Mono', monospace; }

        /* Scroll progress rope */
        #scroll-rope {
            position: fixed;
            left: 0;
            top: 0;
            width: 2px;
            height: 0%;
            background: linear-gradient(to bottom, #D4AF37, #8B6914);
            z-index: 999;
            transition: height 0.1s linear;
        }
        #altitude-marker {
            position: fixed;
            left: 8px;
            bottom: 24px;
            z-index: 998;
            writing-mode: vertical-rl;
            font-family: 'JetBrains Mono', monospace;
            font-size: 9px;
            color: rgba(212,175,55,0.5);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            pointer-events: none;
        }

        .tier-top { border-top: 4px solid var(--db4-gold); }
        .tier-mid { border-top: 4px solid var(--db4-silver); }
        .tier-cellar { border-top: 4px solid var(--db4-rust); }

        .glass {
            background: rgba(20, 20, 24, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
        }

        .premium-shadow { box-shadow: 0 10px 30px -10px rgba(0,0,0,0.7); }

        .rank-gold { color: var(--db4-gold); text-shadow: 0 0 10px rgba(212, 175, 55, 0.3); }

        .gold-card {
            background: linear-gradient(145deg, rgba(212, 175, 55, 0.12) 0%, rgba(20, 20, 24, 0.9) 100%);
            border: 1px solid rgba(212, 175, 55, 0.4);
            box-shadow: 0 0 25px rgba(212, 175, 55, 0.1);
        }

        .badge-icon {
            width: 22px; height: 22px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 50%; font-size: 10px;
            border: 1px solid rgba(255,255,255,0.1);
            transition: transform 0.2s;
            cursor: help;
        }
        .badge-icon:hover { transform: translateY(-2px); }

        .banner-champion {
            background: linear-gradient(to bottom, #004d26 0%, #008542 100%);
            border-left: 12px solid #d4af37;
            position: relative; overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,0,0,0.5);
        }
        .banner-champion::after {
            content: "CHAMPION";
            position: absolute; right: -10px; bottom: -5px;
            font-family: 'Oswald'; font-size: 50px; font-weight: 900;
            opacity: 0.08; transform: rotate(-10deg);
        }

        .tab-active { border-bottom: 2px solid var(--db4-gold); color: white; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade { animation: fadeIn 0.4s ease-out forwards; }

        .nav-link {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }
        .nav-link.active::after {
            content: '';
            position: absolute; bottom: -2px; left: 0;
            width: 100%; height: 2px;
            background: var(--db4-gold);
        }

        .modal-overlay {
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            position: fixed; inset: 0; z-index: 100;
            display: flex; align-items: center; justify-content: center;
            padding: 1rem;
        }
        .modal-overlay.hidden { display: none; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0A0B0E; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }

        .starter-slot { border-left: 3px solid #333; transition: border-color 0.2s; }
        .starter-slot:hover { border-left-color: var(--db4-gold); }

        .immunity-badge { animation: pulse 2s infinite; }
        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 0.8; }
        }

        .relegation-badge { animation: dangerPulse 2s infinite; }
        @keyframes dangerPulse {
            0% { opacity: 0.8; }
            50% { opacity: 1; box-shadow: 0 0 8px rgba(239,68,68,0.5); }
            100% { opacity: 0.8; }
        }

        .dynasty-rank-pill {
            display: inline-flex; align-items: center; gap: 4px;
            font-size: 10px; font-weight: 900; text-transform: uppercase;
            padding: 2px 6px; border-radius: 4px;
            border: 1px solid rgba(255,255,255,0.1);
            letter-spacing: 0.05em;
        }
        .dynasty-rank-pill.gold { background: rgba(212,175,55,0.2); color: #D4AF37; border-color: rgba(212,175,55,0.3); }
        .dynasty-rank-pill.default { background: rgba(255,255,255,0.05); color: #9ca3af; border-color: rgba(255,255,255,0.08); }

        /* D-Score breakdown accordion */
        .dscore-breakdown { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
        .dscore-breakdown.open { max-height: 400px; }

        /* Constitution styles */
        .constitution-article { border-left: 2px solid #222228; transition: border-color 0.2s; }
        .constitution-article:hover { border-left-color: rgba(212,175,55,0.4); }
        .constitution-article.amendment { border-left-color: rgba(212,175,55,0.25); }
        .constitution-body { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }
        .constitution-body.open { max-height: 2000px; }

        /* Timeline */
        .timeline-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: linear-gradient(to bottom, transparent, #D4AF37 10%, #D4AF37 90%, transparent); transform: translateX(-50%); }
        .timeline-node { width: 12px; height: 12px; border-radius: 50%; border: 2px solid #D4AF37; background: #0A0B0E; flex-shrink: 0; }

        /* Dynasty victor banner */
        .dynasty-banner {
            background: linear-gradient(135deg, rgba(212,175,55,0.08) 0%, rgba(10,11,14,0) 60%);
            border: 1px solid rgba(212,175,55,0.2);
            position: relative; overflow: hidden;
        }
        .dynasty-banner::before {
            content: "1ST DYNASTY";
            position: absolute; right: -20px; top: 50%; transform: translateY(-50%) rotate(90deg);
            font-family: 'Oswald'; font-size: 60px; font-weight: 900;
            opacity: 0.03; white-space: nowrap; pointer-events: none;
        }

        /* Trigger progress bar */
        .trigger-bar { height: 4px; background: #222228; border-radius: 2px; overflow: hidden; }
        .trigger-fill { height: 100%; border-radius: 2px; transition: width 0.6s ease; }

        /* Sloppy exception badge */
        .sloppy-badge { background: rgba(139,69,19,0.2); color: #cd853f; border-color: rgba(139,69,19,0.3); }
    </style>
</head>
<body class="min-h-screen pb-20">

    <!-- Scroll Rope -->
    <div id="scroll-rope"></div>
    <div id="altitude-marker">ALT: 0%</div>

    <!-- Header Navigation -->
    <nav class="sticky top-0 z-50 glass border-b border-white/5 py-4">
        <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <!-- SVG Mountain Logo -->
                <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0 drop-shadow-lg">
                    <rect width="44" height="44" rx="8" fill="#0A0B0E"/>
                    <rect width="44" height="44" rx="8" fill="url(#logoGrad)" opacity="0.15"/>
                    <!-- Back mountain (silver/muted) -->
                    <polygon points="30,8 40,34 20,34" fill="#2a2a2a" stroke="#444" stroke-width="0.5"/>
                    <!-- Front mountain (gold) -->
                    <polygon points="14,12 28,34 0,34" fill="url(#peakGrad)"/>
                    <!-- Snow cap -->
                    <polygon points="14,12 18,20 10,20" fill="white" opacity="0.9"/>
                    <!-- Climbing rope line -->
                    <path d="M14,12 L14,38" stroke="#D4AF37" stroke-width="1" stroke-dasharray="2,2" opacity="0.6"/>
                    <!-- Climber dot at peak -->
                    <circle cx="14" cy="12" r="2" fill="#D4AF37"/>
                    <!-- Border glow -->
                    <rect x="0.5" y="0.5" width="43" height="43" rx="7.5" stroke="#D4AF37" stroke-width="0.5" opacity="0.3"/>
                    <defs>
                        <linearGradient id="peakGrad" x1="14" y1="12" x2="14" y2="34" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="#D4AF37"/>
                            <stop offset="100%" stop-color="#5a4a10"/>
                        </linearGradient>
                        <linearGradient id="logoGrad" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
                            <stop offset="0%" stop-color="#D4AF37"/>
                            <stop offset="100%" stop-color="#000"/>
                        </linearGradient>
                    </defs>
                </svg>
                <div>
                    <h1 class="oswald text-2xl tracking-tighter uppercase italic leading-none">
                        <span class="text-white">It's the</span>
                        <span class="rank-gold"> Climb</span>
                    </h1>
                    <p class="text-[8px] mono uppercase tracking-[0.2em] text-gray-600 leading-none mt-0.5">DB4 Sports · Official Portal</p>
                </div>
            </div>

            <div class="flex gap-6 overflow-x-auto pb-2 md:pb-0">
                <button onclick="switchTab('top')" id="btn-top" class="nav-link text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-white active">League HQ</button>
                <button onclick="switchTab('mid')" id="btn-mid" class="nav-link text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-white">Mid League</button>
                <button onclick="switchTab('cellar')" id="btn-cellar" class="nav-link text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-white">The Cellar</button>
                <button onclick="switchTab('rankings')" id="btn-rankings" class="nav-link text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-white">Dynasty Rankings</button>
                <button onclick="switchTab('records')" id="btn-records" class="nav-link text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-white">Permanent Record</button>
                <button onclick="switchTab('history')" id="btn-history" class="nav-link text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-white">History</button>
                <button onclick="switchTab('constitution')" id="btn-constitution" class="nav-link text-sm font-bold uppercase tracking-widest text-gray-400 hover:text-white">Constitution</button>
            </div>

            <a href="https://docs.google.com/document/d/1JASaVRgcu9-bmoVFDSwpHdhnjpSfgMyd99RjWIJc1OY/edit?tab=t.0" target="_blank"
               class="bg-white/5 hover:bg-white/10 px-4 py-2 rounded text-xs font-bold uppercase tracking-tighter border border-white/10 transition-colors whitespace-nowrap">
               <i class="fa-solid fa-scroll mr-2"></i>Google Doc
            </a>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main id="app-content" class="max-w-7xl mx-auto px-4 py-8">

        <!-- Dynasty Victor Banner (shown on league tabs) -->
        <div id="dynasty-banner-section" class="mb-8 dynasty-banner rounded-xl p-4 animate-fade">
            <!-- Top row: icon + title + score -->
            <div class="flex items-center gap-3 mb-3">
                <div class="text-[#D4AF37] text-xl flex-shrink-0"><i class="fa-solid fa-mountain"></i></div>
                <div class="min-w-0">
                    <p class="text-[9px] uppercase tracking-widest text-gray-500 font-bold mono leading-tight">1st Dynasty · Season 4 · 2023–Present</p>
                    <p class="oswald text-base uppercase italic leading-tight">Leader: <span class="rank-gold">Southie Thunder Buddies</span></p>
                </div>
                <div class="ml-auto flex-shrink-0 text-right">
                    <span class="mono text-xl font-bold rank-gold leading-none block">384.00</span>
                    <span class="text-gray-600 text-[9px] mono">D-PTS</span>
                </div>
            </div>
            <!-- Triggers -->
            <div class="border-t border-white/5 pt-3">
                <p class="text-[9px] uppercase tracking-widest text-gray-500 font-bold mono mb-2">Redraft Triggers</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                    <div>
                        <div class="flex justify-between text-[9px] mono text-gray-500 mb-0.5">
                            <span class="truncate pr-1">&gt;½ champs (1 team, Yr4+)</span>
                            <span class="text-yellow-600 flex-shrink-0">1/3</span>
                        </div>
                        <div class="trigger-bar"><div class="trigger-fill bg-yellow-600" style="width:33%"></div></div>
                    </div>
                    <div>
                        <div class="flex justify-between text-[9px] mono text-gray-500 mb-0.5">
                            <span class="truncate pr-1">6 combined champs (2 teams)</span>
                            <span class="text-green-700 flex-shrink-0">3/6</span>
                        </div>
                        <div class="trigger-bar"><div class="trigger-fill bg-green-800" style="width:50%"></div></div>
                    </div>
                    <div>
                        <div class="flex justify-between text-[9px] mono text-gray-500 mb-0.5">
                            <span class="truncate pr-1">Season 10 vote</span>
                            <span class="text-gray-600 flex-shrink-0">Yr 4/10</span>
                        </div>
                        <div class="trigger-bar"><div class="trigger-fill bg-gray-600" style="width:40%"></div></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dashboard Header -->
        <div id="header-section" class="mb-12">
            <h2 id="tier-title" class="oswald text-5xl md:text-7xl font-extrabold uppercase italic tracking-tighter">THE TOP LEVEL</h2>
            <div class="flex items-center gap-4 mt-2">
                <span id="tier-subtitle" class="text-gray-400 font-medium tracking-widest uppercase text-sm">Green Jacket & Gold Jacket Divisions</span>
                <span class="w-12 h-px bg-white/20"></span>
                <span id="team-count" class="text-xs bg-white/10 px-2 py-1 rounded mono">12 TEAMS</span>
            </div>
        </div>

        <!-- Dynamic Content -->
        <div id="live-view" class="space-y-8">
            <div id="loading-spinner" class="flex flex-col items-center py-20">
                <div class="w-12 h-12 border-4 border-white/10 border-t-[#D4AF37] rounded-full animate-spin mb-4"></div>
                <p class="text-sm uppercase tracking-widest animate-pulse mono">Syncing Sleeper Data...</p>
            </div>

            <div id="live-matchups-section" class="hidden">
                <h3 class="oswald text-xl uppercase tracking-wider mb-4 flex items-center">
                    <span class="w-2 h-2 bg-red-600 rounded-full animate-ping mr-3"></span>
                    Live Dashboard — Week <span id="current-week-num" class="ml-1">1</span>
                </h3>
                <div id="matchups-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
            </div>

            <div id="standings-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
        </div>

        <!-- Rankings Tab -->
        <div id="rankings-view" class="hidden">
            <div class="glass rounded-xl overflow-hidden premium-shadow">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white/5 uppercase text-xs tracking-widest font-bold">
                            <th class="p-4 mono">Rank</th>
                            <th class="p-4">Team</th>
                            <th class="p-4 mono">Win %</th>
                            <th class="p-4 mono">D-Score</th>
                            <th class="p-4">Bonuses</th>
                        </tr>
                    </thead>
                    <tbody id="rankings-body"></tbody>
                </table>
            </div>
        </div>

        <!-- Records Tab -->
        <div id="records-view" class="hidden space-y-12">
            <section>
                <h3 class="oswald text-3xl italic uppercase mb-6 border-l-4 border-[#D4AF37] pl-4">Hall of Fame</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="hall-of-fame-grid"></div>
            </section>
            <section>
                <h3 class="oswald text-3xl italic uppercase mb-6 border-l-4 border-white/20 pl-4">Permanent Records</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4" id="records-grid"></div>
            </section>
        </div>

        <!-- History Tab -->
        <div id="history-view" class="hidden">
            <h2 class="oswald text-5xl md:text-7xl font-extrabold uppercase italic tracking-tighter mb-4">Season History</h2>
            <p class="text-gray-500 text-sm mono uppercase tracking-widest mb-12">1st Dynasty · 2023–Present</p>

            <div class="relative">
                <div class="timeline-line hidden md:block"></div>
                <div class="space-y-12 md:space-y-0">

                    <!-- 2023 -->
                    <div class="md:flex md:items-start md:gap-8 md:mb-16">
