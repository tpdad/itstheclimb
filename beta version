                                </div>
                            </div>
                        </div>
                        <div class="hidden md:flex items-center justify-center z-10 relative">
                            <div class="timeline-node ring-4 ring-[#D4AF37]/40" style="width:16px;height:16px;"></div>
                        </div>
                        <div class="md:w-1/2 md:pl-12">
                            <div class="glass rounded-xl p-4 text-xs text-gray-500 mono space-y-1">
