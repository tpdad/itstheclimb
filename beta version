                                    <div class="flex items-center gap-2"><i class="fa-solid fa-layer-group text-blue-400 text-xs"></i><span>Mid League & Cellar added</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="hidden md:flex items-center justify-center z-10 relative">
                            <div class="timeline-node ring-2 ring-[#D4AF37]/30"></div>
